<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:android="http://schemas.android.com/apk/res/android">

    <style name="KeyboardView.MD3" parent="KeyboardView.LXX">
        <item name="android:background">?attr/md3Surface</item>
        <item name="keyBackground">@drawable/btn_keyboard_key_md3</item>
        <item name="functionalKeyBackground">@drawable/btn_keyboard_key_functional_md3</item>
        <item name="spacebarBackground">@drawable/btn_keyboard_key_functional_md3</item>
        <item name="keyTextColor">?attr/md3OnSurface</item>
        <item name="keyTextInactivatedColor">?attr/md3OnSurfaceVariant</item>
        <item name="functionalTextColor">?attr/md3OnSurfaceVariant</item>
        <item name="keyHintLetterColor">@color/md3_hint_letter_color</item>
        <item name="keyHintLabelColor">@color/md3_hint_letter_color</item>
        <item name="keyShiftedLetterHintInactivatedColor">@color/md3_hint_letter_color</item>
        <item name="keyShiftedLetterHintActivatedColor">?attr/md3OnSurface</item>
        <item name="keyPreviewTextColor">?attr/md3OnSurface</item>
        <item name="keyPreviewTextRatio">68%</item>
    </style>

    <style name="MainKeyboardView.MD3" parent="KeyboardView.MD3">
        <item name="moreKeysKeyboardForActionLayout">@layout/more_keys_keyboard_for_action_lxx</item>
        <item name="keyPreviewBackground">@drawable/md3_key_preview_background</item>
        <item name="keyPreviewHeight">68dp</item>
        <item name="keyPreviewElevation">6dp</item>
        <item name="keyPreviewOffset">@dimen/config_key_preview_offset_md3</item>
        <item name="keyPreviewShowUpAnimator">@anim/key_preview_show_up_lxx</item>
        <item name="keyPreviewDismissAnimator">@anim/key_preview_dismiss_lxx</item>
        <item name="gestureFloatingPreviewTextColor">?attr/md3OnSurface</item>
        <item name="gestureFloatingPreviewColor">?attr/md3KeyColor</item>
        <item name="gestureFloatingPreviewRoundRadius">20dp</item>
        <item name="gestureFloatingPreviewElevation">6dp</item>
        <item name="gestureTrailColor">?attr/md3Primary</item>
        <item name="slidingKeyInputPreviewColor">?attr/md3Primary</item>
        <item name="languageOnSpacebarTextColor">?attr/md3OnSurfaceVariant</item>
        <item name="languageOnSpacebarTextShadowRadius">-1.0</item>
    </style>

    <style name="MoreKeysKeyboard.MD3" parent="Keyboard">
        <item name="keyboardTopPadding">0%p</item>
        <item name="keyboardBottomPadding">0%p</item>
        <item name="horizontalGap">0%p</item>
        <item name="verticalGap">0%p</item>
        <item name="touchPositionCorrectionData">@null</item>
    </style>

    <style name="MoreKeysKeyboardView.MD3" parent="KeyboardView.MD3">
        <item name="android:background">@drawable/md3_popup_background</item>
        <item name="android:elevation">6dp</item>
        <item name="keyBackground">@drawable/btn_keyboard_key_popup_md3</item>
        <item name="keyFocusedTextColor">?attr/md3Surface</item>
        <item name="keyHoverHighlight">@drawable/md3_hover_circle</item>
        <item name="keyHoverHighlightRect">@drawable/md3_hover_rect</item>
        <item name="keySingleBackground">@drawable/md3_popup_background_circle</item>
        <item name="divider">@drawable/more_keys_divider</item>
        <item name="keyTypeface">normal</item>
        <item name="verticalCorrection">@dimen/config_more_keys_keyboard_vertical_correction_holo</item>
    </style>

    <style name="MoreKeysKeyboardView.MD3.Action" parent="MoreKeysKeyboardView.MD3">
        <item name="android:background">@drawable/md3_popup_background</item>
        <item name="android:elevation">6dp</item>
        <item name="keyBackground">@drawable/btn_keyboard_key_popup_md3</item>
        <item name="divider">@null</item>
        <item name="keyLabelFlags">keepBackgroundAspectRatio</item>
    </style>

    <style name="SuggestionStripView.MD3" parent="KeyboardView.MD3">
        <item name="suggestionsCountInStrip">@integer/config_suggestions_count_in_strip</item>
        <item name="centerSuggestionPercentile">@fraction/config_center_suggestion_percentile</item>
        <item name="maxMoreSuggestionsRow">@integer/config_max_more_suggestions_row</item>
        <item name="minMoreSuggestionsWidth">@fraction/config_min_more_suggestions_width</item>
        <item name="android:background">?attr/md3Surface</item>
        <item name="android:src">@drawable/md3_suggestion_divider</item>
        <item name="suggestionStripOptions">autoCorrectBold|validTypedWordBold</item>
        <item name="colorValidTypedWord">?attr/md3OnSurface</item>
        <item name="colorTypedWord">?attr/md3OnSurface</item>
        <item name="colorAutoCorrect">?attr/md3Primary</item>
        <item name="colorSuggested">?attr/md3OnSurfaceVariant</item>
        <item name="alphaObsoleted">70%</item>
        <item name="voiceKeyBackground">@drawable/suggestion_strip_voice_card</item>
    </style>

    <style name="SuggestionWord.MD3" parent="SuggestionWord">
        <item name="android:background">@null</item>
        <item name="android:textColor">?attr/md3OnSurface</item>
    </style>

    <style name="EmojiPalettesView.MD3" parent="MainKeyboardView.MD3">
        <item name="categoryIndicatorEnabled">false</item>
        <item name="categoryPageIndicatorColor">?attr/md3Primary</item>
        <item name="iconEmojiRecentsTab">@drawable/ic_kb_tab_recents</item>
        <item name="iconEmojiCategory1Tab">@drawable/ic_kb_tab_people</item>
        <item name="iconEmojiCategory2Tab">@drawable/ic_kb_tab_objects</item>
        <item name="iconEmojiCategory3Tab">@drawable/ic_kb_tab_nature</item>
        <item name="iconEmojiCategory4Tab">@drawable/ic_kb_tab_places</item>
        <item name="iconEmojiCategory5Tab">@drawable/ic_kb_tab_symbols</item>
        <item name="iconEmojiCategory6Tab">@drawable/ic_kb_tab_emoticons</item>
        <item name="iconEmojiCategory7Tab">@drawable/ic_kb_tab_flag</item>
        <item name="iconEmojiCategory8Tab">@drawable/ic_kb_tab_people</item>
        <item name="iconEmojiCategory9Tab">@drawable/ic_kb_tab_nature</item>
        <item name="iconEmojiCategory10Tab">@drawable/ic_kb_tab_food</item>
        <item name="iconEmojiCategory11Tab">@drawable/ic_kb_tab_places</item>
        <item name="iconEmojiCategory12Tab">@drawable/ic_kb_tab_activity</item>
        <item name="iconEmojiCategory13Tab">@drawable/ic_kb_tab_objects</item>
        <item name="iconEmojiCategory14Tab">@drawable/ic_kb_tab_symbols</item>
        <item name="iconEmojiCategory15Tab">@drawable/ic_kb_tab_flag</item>
        <item name="iconEmojiCategory16Tab">@drawable/ic_kb_tab_people_body</item>
    </style>

    <style name="Keyboard.MD3" parent="Keyboard">
        <item name="moreKeysTemplate">@xml/kbd_more_keys_keyboard_template_md3</item>
    </style>
    <style name="Keyboard.MD3_Light" parent="Keyboard.MD3">
        <item name="themeId">MD3Light</item>
    </style>
    <style name="Keyboard.MD3_Dark" parent="Keyboard.MD3">
        <item name="themeId">MD3Dark</item>
    </style>
    <style name="Keyboard.MD3_Dynamic" parent="Keyboard.MD3">
        <item name="themeId">MD3Dynamic</item>
    </style>

    <style name="KeyboardTheme.MD3_Light" parent="KeyboardIcons.MD3">
        <item name="md3Surface">@color/md3_light_surface</item>
        <item name="md3KeyColor">@color/md3_light_key</item>
        <item name="md3KeyPressedColor">@color/md3_light_key_pressed</item>
        <item name="md3FunctionalKeyColor">@color/md3_light_functional</item>
        <item name="md3ActionKeyColor">@color/md3_light_action</item>
        <item name="md3ActionKeyPressedColor">@color/md3_light_action_pressed</item>
        <item name="md3OnSurface">@color/md3_light_on_surface</item>
        <item name="md3OnSurfaceVariant">@color/md3_light_on_surface_variant</item>
        <item name="md3Primary">@color/md3_light_primary</item>
        <item name="md3OnPrimary">@color/md3_light_on_primary</item>
        <item name="inputViewStyle">@style/InputView.LXX</item>
        <item name="keyboardStyle">@style/Keyboard.MD3_Light</item>
        <item name="keyboardViewStyle">@style/KeyboardView.MD3</item>
        <item name="mainKeyboardViewStyle">@style/MainKeyboardView.MD3</item>
        <item name="emojiPalettesViewStyle">@style/EmojiPalettesView.MD3</item>
        <item name="moreKeysKeyboardStyle">@style/MoreKeysKeyboard.MD3</item>
        <item name="moreKeysKeyboardViewStyle">@style/MoreKeysKeyboardView.MD3</item>
        <item name="moreKeysKeyboardViewForActionStyle">@style/MoreKeysKeyboardView.MD3.Action</item>
        <item name="suggestionStripViewStyle">@style/SuggestionStripView.MD3</item>
        <item name="suggestionWordStyle">@style/SuggestionWord.MD3</item>
    </style>

    <style name="KeyboardTheme.MD3_Dark" parent="KeyboardIcons.MD3">
        <item name="md3Surface">@color/md3_dark_surface</item>
        <item name="md3KeyColor">@color/md3_dark_key</item>
        <item name="md3KeyPressedColor">@color/md3_dark_key_pressed</item>
        <item name="md3FunctionalKeyColor">@color/md3_dark_functional</item>
        <item name="md3ActionKeyColor">@color/md3_dark_action</item>
        <item name="md3ActionKeyPressedColor">@color/md3_dark_action_pressed</item>
        <item name="md3OnSurface">@color/md3_dark_on_surface</item>
        <item name="md3OnSurfaceVariant">@color/md3_dark_on_surface_variant</item>
        <item name="md3Primary">@color/md3_dark_primary</item>
        <item name="md3OnPrimary">@color/md3_dark_on_primary</item>
        <item name="inputViewStyle">@style/InputView.LXX</item>
        <item name="keyboardStyle">@style/Keyboard.MD3_Dark</item>
        <item name="keyboardViewStyle">@style/KeyboardView.MD3</item>
        <item name="mainKeyboardViewStyle">@style/MainKeyboardView.MD3</item>
        <item name="emojiPalettesViewStyle">@style/EmojiPalettesView.MD3</item>
        <item name="moreKeysKeyboardStyle">@style/MoreKeysKeyboard.MD3</item>
        <item name="moreKeysKeyboardViewStyle">@style/MoreKeysKeyboardView.MD3</item>
        <item name="moreKeysKeyboardViewForActionStyle">@style/MoreKeysKeyboardView.MD3.Action</item>
        <item name="suggestionStripViewStyle">@style/SuggestionStripView.MD3</item>
        <item name="suggestionWordStyle">@style/SuggestionWord.MD3</item>
    </style>

    <style name="KeyboardTheme.MD3_Dynamic" parent="KeyboardIcons.MD3">
        <item name="md3Surface">@color/md3_dynamic_surface</item>
        <item name="md3KeyColor">@color/md3_dynamic_key</item>
        <item name="md3KeyPressedColor">@color/md3_dynamic_key_pressed</item>
        <item name="md3FunctionalKeyColor">@color/md3_dynamic_functional</item>
        <item name="md3ActionKeyColor">@color/md3_dynamic_action</item>
        <item name="md3ActionKeyPressedColor">@color/md3_dynamic_action_pressed</item>
        <item name="md3OnSurface">@color/md3_dynamic_on_surface</item>
        <item name="md3OnSurfaceVariant">@color/md3_dynamic_on_surface_variant</item>
        <item name="md3Primary">@color/md3_dynamic_primary</item>
        <item name="md3OnPrimary">@color/md3_dynamic_on_primary</item>
        <item name="inputViewStyle">@style/InputView.LXX</item>
        <item name="keyboardStyle">@style/Keyboard.MD3_Dynamic</item>
        <item name="keyboardViewStyle">@style/KeyboardView.MD3</item>
        <item name="mainKeyboardViewStyle">@style/MainKeyboardView.MD3</item>
        <item name="emojiPalettesViewStyle">@style/EmojiPalettesView.MD3</item>
        <item name="moreKeysKeyboardStyle">@style/MoreKeysKeyboard.MD3</item>
        <item name="moreKeysKeyboardViewStyle">@style/MoreKeysKeyboardView.MD3</item>
        <item name="moreKeysKeyboardViewForActionStyle">@style/MoreKeysKeyboardView.MD3.Action</item>
        <item name="suggestionStripViewStyle">@style/SuggestionStripView.MD3</item>
        <item name="suggestionWordStyle">@style/SuggestionWord.MD3</item>
    </style>
</resources>
