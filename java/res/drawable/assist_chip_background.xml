<!-- M3 assist chip container shared by the clipboard chip and the inline autofill chips:
     14% fill plus a 1dp 50% outline. Dark ink, for light keyboards — pick via
     ClipboardHistoryView.assistChipBackgroundRes. Literal colors because the remote autofill
     renderer can resolve neither theme attributes nor a runtime tint without flattening the
     per-layer alphas. -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#2446464F" />
            <corners android:radius="8dp" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <stroke android:width="1dp" android:color="#8046464F" />
            <corners android:radius="8dp" />
        </shape>
    </item>
</layer-list>
