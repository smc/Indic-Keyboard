<merge
    xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Provide audio and haptic feedback by ourselves based on the keyboard settings.
         We just need to ignore the system's audio and haptic feedback settings. -->
    <ImageButton
        android:id="@+id/suggestions_strip_voice_key"
        android:layout_width="@dimen/config_suggestions_strip_edge_key_width"
        android:layout_height="fill_parent"
        android:layout_alignParentEnd="true"
        android:layout_alignParentRight="true"
        android:layout_centerVertical="true"
        android:contentDescription="@string/spoken_description_mic"
        style="?attr/suggestionWordStyle" />
    <!-- Center area, always inset by one edge-key slot on each side so its contents stay centered
         regardless of whether the right sticky slot shows the voice/more key. -->
    <LinearLayout
        android:id="@+id/suggestions_strip"
        android:orientation="horizontal"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginStart="@dimen/config_suggestions_strip_edge_key_width"
        android:layout_marginEnd="@dimen/config_suggestions_strip_edge_key_width"
        android:hapticFeedbackEnabled="false"
        android:soundEffectsEnabled="false" />
    <LinearLayout
        android:id="@+id/important_notice_strip"
        android:orientation="horizontal"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginStart="@dimen/config_suggestions_strip_edge_key_width"
        android:layout_marginEnd="@dimen/config_suggestions_strip_edge_key_width"
        android:hapticFeedbackEnabled="false"
        android:soundEffectsEnabled="false" >
        <TextView
            android:id="@+id/important_notice_title"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="6sp"
            android:textSize="16sp"
            style="?attr/suggestionWordStyle" />
    </LinearLayout>
    <LinearLayout
        android:id="@+id/clipboard_chip_strip"
        android:orientation="horizontal"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:hapticFeedbackEnabled="false"
        android:soundEffectsEnabled="false"
        android:contentDescription="@string/clipboard_chip_description" >
        <View
            android:layout_width="@dimen/config_suggestions_strip_edge_key_width"
            android:layout_height="0dip" />
        <View
            android:layout_width="0dip"
            android:layout_weight="1"
            android:layout_height="0dip" />
        <LinearLayout
            android:id="@+id/clipboard_chip_pill"
            android:orientation="horizontal"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:gravity="center_vertical"
            android:paddingLeft="8dp"
            android:paddingRight="16dp" >
            <ImageView
                android:id="@+id/clipboard_chip_icon"
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@drawable/ic_kb_paste_go"
                android:importantForAccessibility="no" />
            <ImageView
                android:id="@+id/clipboard_chip_image"
                android:layout_width="wrap_content"
                android:layout_height="24dp"
                android:adjustViewBounds="true"
                android:layout_marginStart="8dp"
                android:contentDescription="@string/clipboard_image_description"
                android:visibility="gone" />
            <TextView
                android:id="@+id/clipboard_chip_text"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:maxWidth="220dp"
                android:gravity="center_vertical"
                android:layout_marginStart="8dp"
                android:textSize="14sp"
                android:textColor="?attr/md3OnSurfaceVariant"
                android:singleLine="true"
                android:ellipsize="end" />
        </LinearLayout>
        <View
            android:layout_width="0dip"
            android:layout_weight="1"
            android:layout_height="0dip" />
        <ImageView
            android:id="@+id/clipboard_chip_open_history"
            android:layout_width="@dimen/config_suggestions_strip_edge_key_width"
            android:layout_height="match_parent"
            android:scaleType="center"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true"
            android:contentDescription="@string/clipboard_open_history" />
    </LinearLayout>
    <HorizontalScrollView
        android:id="@+id/inline_suggestions_strip"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginStart="@dimen/config_suggestions_strip_edge_key_width"
        android:layout_marginEnd="@dimen/config_suggestions_strip_edge_key_width"
        android:scrollbars="none"
        android:fillViewport="true"
        android:hapticFeedbackEnabled="false"
        android:soundEffectsEnabled="false" >
        <LinearLayout
            android:id="@+id/inline_suggestions_container"
            android:orientation="horizontal"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:paddingLeft="4dp"
            android:paddingRight="4dp"
            android:gravity="center_vertical" />
    </HorizontalScrollView>
    <FrameLayout
        android:id="@+id/suggestions_strip_toolbox"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginStart="@dimen/config_suggestions_strip_edge_key_width"
        android:layout_marginEnd="@dimen/config_suggestions_strip_edge_key_width"
        android:visibility="invisible" >
    <LinearLayout
        android:id="@+id/suggestions_strip_toolbox_row"
        android:orientation="horizontal"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center_vertical"
        android:hapticFeedbackEnabled="false"
        android:soundEffectsEnabled="false" >
        <View
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="0dp" />
        <ImageButton
            android:id="@+id/toolbox_settings_key"
            android:layout_width="64dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_kb_settings"
            android:scaleType="fitCenter"
            android:padding="6dp"
            android:contentDescription="@string/spoken_description_settings" />
        <View
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="0dp" />
        <ImageButton
            android:id="@+id/toolbox_clipboard_key"
            android:layout_width="64dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_kb_clipboard"
            android:scaleType="fitCenter"
            android:padding="6dp"
            android:contentDescription="@string/settings_screen_clipboard" />
        <View
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="0dp" />
        <ImageButton
            android:id="@+id/toolbox_emoji_key"
            android:layout_width="64dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_kb_emoji"
            android:scaleType="fitCenter"
            android:padding="6dp"
            android:contentDescription="@string/spoken_description_emoji" />
        <View
            android:id="@+id/toolbox_companion_spacer"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="0dp"
            android:visibility="gone" />
        <ImageButton
            android:id="@+id/toolbox_companion_key"
            android:layout_width="64dp"
            android:layout_height="32dp"
            android:scaleType="fitCenter"
            android:padding="6dp"
            android:visibility="gone"
            android:contentDescription="@string/companion_toggle_description" />
        <View
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="0dp" />
    </LinearLayout>
    </FrameLayout>
    <ImageButton
        android:id="@+id/suggestions_strip_more_key"
        android:layout_width="@dimen/config_suggestions_strip_edge_key_width"
        android:layout_height="fill_parent"
        android:layout_alignParentEnd="true"
        android:layout_alignParentRight="true"
        android:layout_centerVertical="true"
        android:contentDescription="@string/spoken_description_more"
        style="?attr/suggestionWordStyle" />
    <ImageButton
        android:id="@+id/suggestions_strip_menu_key"
        android:layout_width="@dimen/config_suggestions_strip_edge_key_width"
        android:layout_height="fill_parent"
        android:layout_alignParentStart="true"
        android:layout_centerVertical="true"
        android:src="@drawable/ic_kb_menu"
        android:contentDescription="@string/suggestion_strip_toolbox_menu"
        style="?attr/suggestionWordStyle" />
</merge>
