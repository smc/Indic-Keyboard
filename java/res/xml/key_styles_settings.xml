<merge
    xmlns:latin="http://schemas.android.com/apk/res-auto"
>
    <!-- Base key style for the key which may have settings key as more keys. -->
    <!-- Kept as a separate file for cleaner overriding by an overlay.  -->
    <switch>
        <case
            latin:clobberSettingsKey="true"
        >
            <key-style
                latin:styleName="settingsMoreKeysStyle"
                latin:keyLabelFlags="hasPopupHint"
                latin:additionalMoreKeys="!text/keyspec_clipboard"
                latin:backgroundType="functional"
                latin:parentStyle="baseSettingsMoreKeysStyle" />
        </case>
        <!-- clobberSettingsKey="false" -->
        <default>
            <key-style
                latin:styleName="settingsMoreKeysStyle"
                latin:keyLabelFlags="hasPopupHint"
                latin:additionalMoreKeys="!text/keyspec_clipboard,!text/keyspec_settings"
                latin:backgroundType="functional"
                latin:parentStyle="baseSettingsMoreKeysStyle" />
        </default>
    </switch>
    <!-- Function key for pc-style (inscript) layouts: tapping shows the same popover the
         comma key offers on long press elsewhere, with emoji folded in. -->
    <switch>
        <case
            latin:clobberSettingsKey="true"
        >
            <key-style
                latin:styleName="functionMenuKeyStyle"
                latin:keySpec="!icon/settings_key|!code/key_function_menu"
                latin:keyLabelFlags="hasPopupHint"
                latin:moreKeys="!icon/emoji_normal_key|!code/key_emoji,!text/keyspec_clipboard"
                latin:keyActionFlags="noKeyPreview"
                latin:backgroundType="functional" />
        </case>
        <!-- clobberSettingsKey="false" -->
        <default>
            <key-style
                latin:styleName="functionMenuKeyStyle"
                latin:keySpec="!icon/settings_key|!code/key_function_menu"
                latin:keyLabelFlags="hasPopupHint"
                latin:moreKeys="!icon/emoji_normal_key|!code/key_emoji,!text/keyspec_clipboard,!text/keyspec_settings"
                latin:keyActionFlags="noKeyPreview"
                latin:backgroundType="functional" />
        </default>
    </switch>
</merge>
