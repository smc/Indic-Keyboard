<!-- The numeric/math pad: a centered calculator digit cluster with formula structure on the
     left, arithmetic operators and editing on the right. Language-independent. -->
<merge
    xmlns:latin="http://schemas.android.com/apk/res-auto"
>
    <include
        latin:keyboardLayout="@xml/key_styles_common" />
    <include
        latin:keyboardLayout="@xml/key_styles_number" />
    <include
        latin:keyboardLayout="@xml/key_styles_currency" />
    <key-style
        latin:styleName="numPadOperatorKeyStyle"
        latin:backgroundType="functional"
        latin:keyLetterSize="45%"
        latin:parentStyle="numKeyBaseStyle" />
    <key-style
        latin:styleName="toAlphaFromNumericPadKeyStyle"
        latin:keySpec="!text/keylabel_to_alpha|!code/key_alpha_from_numeric_pad"
        latin:keyLabelFlags="preserveCase|followFunctionalTextColor|autoXScale"
        latin:parentStyle="baseForLayoutSwitchKeyStyle" />
    <Row>
        <!-- U+005B: "[" U+007B: "{" -->
        <Key
            latin:keySpec="("
            latin:moreKeys="&#x005B;,&#x007B;"
            latin:keyHintLabel="["
            latin:keyStyle="numPadOperatorKeyStyle" />
        <Key
            latin:keyStyle="currencyKeyStyle"
            latin:keyHintLabel="$"
            latin:keyLetterSize="45%"
            latin:backgroundType="functional" />
        <Key
            latin:keySpec="7"
            latin:keyStyle="numKeyStyle"
            latin:keyWidth="16%p" />
        <Key
            latin:keySpec="8"
            latin:keyStyle="numKeyStyle"
            latin:keyWidth="16%p" />
        <Key
            latin:keySpec="9"
            latin:keyStyle="numKeyStyle"
            latin:keyWidth="16%p" />
        <!-- U+00F7: "÷" DIVISION SIGN -->
        <Key
            latin:keySpec="/"
            latin:moreKeys="&#x00F7;"
            latin:keyHintLabel="&#x00F7;"
            latin:keyStyle="numPadOperatorKeyStyle" />
        <Key
            latin:keySpec="\%"
            latin:keyStyle="numPadOperatorKeyStyle"
            latin:keyWidth="fillRight" />
    </Row>
    <Row>
        <!-- U+005D: "]" U+007D: "}" -->
        <Key
            latin:keySpec=")"
            latin:moreKeys="&#x005D;,&#x007D;"
            latin:keyHintLabel="]"
            latin:keyStyle="numPadOperatorKeyStyle" />
        <Key
            latin:keySpec=":"
            latin:keyStyle="numPadOperatorKeyStyle" />
        <Key
            latin:keySpec="4"
            latin:keyStyle="numKeyStyle"
            latin:keyWidth="16%p" />
        <Key
            latin:keySpec="5"
            latin:keyStyle="numKeyStyle"
            latin:keyWidth="16%p" />
        <Key
            latin:keySpec="6"
            latin:keyStyle="numKeyStyle"
            latin:keyWidth="16%p" />
        <!-- U+00D7: "×" MULTIPLICATION SIGN
             U+00B7: "·" MIDDLE DOT -->
        <Key
            latin:keySpec="*"
            latin:moreKeys="&#x00D7;,^,&#x00B7;"
            latin:keyHintLabel="&#x00D7;"
            latin:keyStyle="numPadOperatorKeyStyle" />
        <Key
            latin:keyStyle="numSpaceKeyStyle"
            latin:keyWidth="fillRight" />
    </Row>
    <Row>
        <!-- U+2260: "≠" NOT EQUAL TO
             U+2248: "≈" ALMOST EQUAL TO -->
        <Key
            latin:keySpec="="
            latin:moreKeys="&#x2260;,&#x2248;"
            latin:keyHintLabel="&#x2260;"
            latin:keyStyle="numPadOperatorKeyStyle" />
        <Key
            latin:keySpec="!text/keyspec_symbols_semicolon"
            latin:keyStyle="numPadOperatorKeyStyle" />
        <Key
            latin:keySpec="1"
            latin:keyStyle="numKeyStyle"
            latin:keyWidth="16%p" />
        <Key
            latin:keySpec="2"
            latin:keyStyle="numKeyStyle"
            latin:keyWidth="16%p" />
        <Key
            latin:keySpec="3"
            latin:keyStyle="numKeyStyle"
            latin:keyWidth="16%p" />
        <!-- U+00B1: "±" PLUS-MINUS SIGN
             U+2013: "–" EN DASH
             U+2014: "—" EM DASH -->
        <Key
            latin:keySpec="-"
            latin:moreKeys="&#x00B1;,&#x2013;,&#x2014;"
            latin:keyHintLabel="&#x00B1;"
            latin:keyStyle="numPadOperatorKeyStyle" />
        <Key
            latin:keyStyle="deleteKeyStyle"
            latin:keyWidth="fillRight" />
    </Row>
    <Row>
        <Key
            latin:keyStyle="toAlphaFromNumericPadKeyStyle" />
        <Key
            latin:keySpec="00"
            latin:keyLabelFlags="autoXScale"
            latin:keyLetterSize="55%"
            latin:keyStyle="numPadOperatorKeyStyle" />
        <Key
            latin:keySpec="!text/keyspec_comma"
            latin:keyStyle="numKeyStyle"
            latin:keyWidth="16%p" />
        <Key
            latin:keySpec="0"
            latin:keyStyle="numKeyStyle"
            latin:keyWidth="16%p" />
        <Key
            latin:keySpec="."
            latin:keyStyle="numKeyStyle"
            latin:keyWidth="16%p" />
        <Key
            latin:keySpec="+"
            latin:keyStyle="numPadOperatorKeyStyle" />
        <Key
            latin:keyStyle="enterKeyStyle"
            latin:keyWidth="fillRight" />
    </Row>
</merge>
